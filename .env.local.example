# ─── Required ────────────────────────────────────────────────────────────────
# Hermes must be installed and accessible. By default the app resolves it from
# your PATH. Override here if you installed it somewhere non-standard.
# HERMES_BIN=hermes

# ─── Optional ─────────────────────────────────────────────────────────────────
# Google Cloud Text-to-Speech API key — only needed for voice/TTS mode.
# Get one at: https://console.cloud.google.com/apis/library/texttospeech.googleapis.com
# If omitted, TTS is silently disabled; everything else works normally.
# GOOGLE_API_KEY=your_key_here

# Custom path for the SQLite database file (default: ./data/super-hank-chat.db)
# DATABASE_PATH=./data/super-hank-chat.db
